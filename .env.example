# =============================================================================
# Tulpin Shop - Environment Variables Template
# =============================================================================
# Скопируйте этот файл в .env и заполните значениями
# cp .env.example .env
# =============================================================================

# ------------------------------------------------------------------------------
# Django Settings
# ------------------------------------------------------------------------------
# Генерация секретного ключа: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-your-secret-key-here

# Debug режим (True/False) - в production всегда False!
DJANGO_DEBUG=False

# Разрешённые хосты (через запятую)
ALLOWED_HOSTS=tlpn.shop,www.tlpn.shop,localhost,127.0.0.1

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
# Путь к SQLite базе данных
# Production: /opt/db/db.sqlite3
# Local: db.sqlite3 (в корне проекта)
DB_PATH=/opt/db/db.sqlite3

# ------------------------------------------------------------------------------
# Static and Media Files (production)
# ------------------------------------------------------------------------------
STATIC_ROOT=/var/www/tlpn_shop/static
MEDIA_ROOT=/var/www/tlpn_shop/media

# ------------------------------------------------------------------------------
# Telegram Bot Settings
# ------------------------------------------------------------------------------
# Получить токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=

# Ваш Telegram User ID (можно узнать у @userinfobot)
TELEGRAM_ADMIN_ID=

# URL WebApp (ваш домен)
TELEGRAM_WEBAPP_URL=https://tlpn.shop

# ------------------------------------------------------------------------------
# Email Settings (опционально)
# ------------------------------------------------------------------------------
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=your-email@gmail.com

# ------------------------------------------------------------------------------
# Production Settings
# ------------------------------------------------------------------------------
# Путь к статическим файлам (для collectstatic)
STATIC_ROOT=/var/www/tlpn_shop/static

# Путь к медиа файлам
MEDIA_ROOT=/var/www/tlpn_shop/media
