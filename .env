# Django settings
SECRET_KEY=your-secret-key-here
DEBUG=False
DJANGO_DEBUG=False
ALLOWED_HOSTS=tlpn.shop,www.tlpn.shop,localhost,127.0.0.1

# Database (production path)
DB_PATH=/opt/db/db.sqlite3

# Static and Media roots (production paths)
STATIC_ROOT=/var/www/tlpn_shop/static
MEDIA_ROOT=/var/www/tlpn_shop/media

# Telegram Bot Settings
# Get token from @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=

# WebApp URL (use ngrok or your domain for production)
TELEGRAM_WEBAPP_URL=https://tlpn.shop
